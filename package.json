{
  "name": "stampy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Digital loyalty stamp cards in Apple Wallet for Malaysian cafés — no customer app.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e-local.ts",
    "typecheck": "tsc --noEmit",
    "art": "tsx scripts/generate-art.ts",
    "prepare-certs": "tsx scripts/prepare-certs.ts",
    "prepare-google": "tsx scripts/prepare-google.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "^1.4.0",
    "passkit-generator": "^3.3.4",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "embedded-postgres": "18.4.0-beta.17",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
